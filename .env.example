# ── LLM Provider (choose one) ──
# Set LLM_PROVIDER to "sarvam" or "openrouter" (default: auto-detect based on available keys)
# LLM_PROVIDER=sarvam

# Sarvam AI (recommended — BYOK)
SARVAM_API_KEY=your_sarvam_api_key_here

# OpenRouter (fallback)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── Data ──
CSV_FILE=transactionsmore.csv

# ── Environment ──
# ENV=production  (set by Dockerfile; disables hot-reload)
# PORT=8000       (set by Railway automatically)
